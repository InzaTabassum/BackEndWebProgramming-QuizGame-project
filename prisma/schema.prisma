generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model question {
  id       Int       @id @default(autoincrement())
  question    String    
  Answer    String
  keywords Keyword[]

  @@map("questions")
}

model Keyword {
  id    Int    @id @default(autoincrement())
  name  String @unique @db.VarChar(100)
  questions question[]

  @@map("keywords")
}
